{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://surgisense.onrender.com/api/$1" },
    { "source": "/ws/(.*)",  "destination": "https://surgisense.onrender.com/ws/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}